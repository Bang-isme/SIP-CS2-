                                "exec": [
                                    "const runId = pm.collectionVariables.get('runId') || Date.now().toString();",
                                    "pm.collectionVariables.set('nonAdminUsername', `plain_user_${runId}`);",
                                    "pm.collectionVariables.set('nonAdminEmail', `plain_${runId}@example.com`);",
                                    "pm.collectionVariables.set('nonAdminPassword', 'Passw0rd!123');"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status is 200', function () {",
                                    "  pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const body = pm.response.json();",
                                    "",
                                    "pm.test('Signup remains user role', function () {",
                                    "  pm.expect(body.data.roles).to.eql(['user']);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
