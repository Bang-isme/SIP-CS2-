# ===========================================
# SIP_CS Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# MongoDB Configuration
# ===========================================
MONGODB_URI=mongodb://localhost:27017/apicompany

# ===========================================
# MySQL Configuration (Payroll Database)
# ===========================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=payroll_db
MYSQL_AUTO_SYNC=true
MYSQL_REQUIRE_MIGRATIONS=false

# ===========================================
# Server Configuration
# ===========================================
PORT=4000
SA_PORT=4000
PAYROLL_PORT=4100
DASHBOARD_PORT=4200
NODE_ENV=development
SERVER_SHUTDOWN_TIMEOUT_MS=5000

# ===========================================
# Security - CHANGE THESE IN PRODUCTION!
# ===========================================
SECRET=your_jwt_secret_key_change_in_production
REFRESH_SECRET=your_refresh_secret_key_change_in_production
INTERNAL_SERVICE_SECRET=your_internal_service_secret_change_in_production
ACCESS_TOKEN_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_MAX_PERSISTED_SESSIONS=5
# Production notes:
# - REFRESH_SECRET should be different from SECRET
# - INTERNAL_SERVICE_SECRET should be different from SECRET
# - AUTH_COOKIE_SECURE must be true

# ===========================================
# Admin Account (Initial Setup)
# ===========================================
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password
SKIP_AUTH_SEED=1
# Comma-separated allowlist for browser origins that may call this API.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4000,http://localhost:4100,http://localhost:4200
ACTIVE_INTEGRATIONS=payroll
SA_PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api
PAYROLL_INTERNAL_API_BASE_URL=http://127.0.0.1:4100/api/payroll/internal
# Set to 1 only for development/test when Mongo token writes are unavailable
# (for example Atlas storage quota) and you intentionally want read-only demo login via stateless JWT.
# Production ignores this flag.
ALLOW_STATELESS_JWT_FALLBACK=0

# ===========================================
# Dashboard Cache
# ===========================================
DASHBOARD_CACHE_TTL_MS=300000
DASHBOARD_CACHE_MAX_ENTRIES=250
DASHBOARD_CACHE_SWEEP_INTERVAL_MS=60000

# ===========================================
# Drilldown Export
# ===========================================
DRILLDOWN_EXPORT_BATCH_SIZE=5000
DRILLDOWN_FULL_SUMMARY_MAX_COUNT=10000

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
# Set to verbose only when you explicitly want HTTP access logs during test flows.
HTTP_LOG_LEVEL=

# ===========================================
# Outbox / Integration Worker (Case Study 4)
# ===========================================
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_PROCESSING_TIMEOUT_MS=900000
OUTBOX_STOP_TIMEOUT_MS=5000
SYNC_RETRY_BATCH_LIMIT=100

# ===========================================
# Dashboard Aggregation Worker
# ===========================================
# Enables a lightweight scheduler that runs the existing aggregation script
# on a fixed interval to refresh summary tables.
DASHBOARD_AGGREGATION_ENABLED=true
DASHBOARD_AGGREGATION_INTERVAL_MS=1800000
DASHBOARD_AGGREGATION_ON_START=true
DASHBOARD_AGGREGATION_AWAIT_ON_START=false
DASHBOARD_AGGREGATION_TARGET_YEAR=2026
DASHBOARD_AGGREGATION_SKIP_SNAPSHOT=false
DASHBOARD_AGGREGATION_STOP_TIMEOUT_MS=5000
DASHBOARD_FRESHNESS_THRESHOLD_MINUTES=120
CASE3_PREPARE_DASHBOARD_DEMO=1
DASHBOARD_DEMO_ALERT_NOTE=Demo baseline reviewed for current alert snapshot.

# Script/runtime compatibility aliases used by seeding and aggregation helpers.
AGG_SKIP_EMPLOYEE_SNAPSHOT=0
SEED_PROFILE=enterprise
SEED_TOTAL_RECORDS=500000
SEED_BATCH_SIZE=5000
SEED_ADMIN_PASSWORD=
MYSQL_DB=payroll_db
SOURCE_MONGODB_URI=
SOURCE_MONGODB_DB=
TARGET_MONGODB_URI=
TARGET_MONGODB_DB=
MONGO_CLONE_BATCH_SIZE=2000

# ===========================================
# Local Runtime / Doctor
# ===========================================
LOCAL_BACKEND_BASE_URL=http://127.0.0.1:4000
LOCAL_DATASET_TARGET=500000
